{
  "bsonType": "object",
  "required": ["name", "type", "creatorId", "createTime"],
  "properties": {
    "_id": {
      "description": "组织ID"
    },
    "name": {
      "bsonType": "string",
      "title": "组织名称",
      "description": "组织名称"
    },
    "type": {
      "bsonType": "string",
      "title": "组织类型",
      "description": "组织类型：region-地域/industry-行业/grade-年级/interest-兴趣",
      "enum": ["region", "industry", "grade", "interest"]
    },
    "logo": {
      "bsonType": "string",
      "title": "组织Logo",
      "description": "组织Logo图片URL"
    },
    "description": {
      "bsonType": "string",
      "title": "组织简介",
      "description": "组织简介"
    },
    "creatorId": {
      "bsonType": "string",
      "title": "创建者ID",
      "description": "创建者用户ID",
      "foreignKey": "uni-id-users._id"
    },
    "adminIds": {
      "bsonType": "array",
      "title": "管理员ID列表",
      "description": "管理员用户ID列表",
      "items": {
        "bsonType": "string"
      }
    },
    "memberCount": {
      "bsonType": "int",
      "title": "成员数量",
      "description": "组织成员数量",
      "default": 1
    },
    "joinType": {
      "bsonType": "string",
      "title": "加入方式",
      "description": "加入方式：open-开放/audit-审核/invite-邀请",
      "enum": ["open", "audit", "invite"],
      "default": "open"
    },
    "status": {
      "bsonType": "int",
      "title": "组织状态",
      "description": "0-草稿 1-正常 2-已解散",
      "enum": [0, 1, 2],
      "default": 0
    },
    "auditStatus": {
      "bsonType": "int",
      "title": "审核状态",
      "description": "0-待审核 1-已通过 2-已拒绝",
      "enum": [0, 1, 2],
      "default": 0
    },
    "auditTime": {
      "bsonType": "timestamp",
      "title": "审核时间",
      "description": "审核时间"
    },
    "auditRemark": {
      "bsonType": "string",
      "title": "审核备注",
      "description": "审核备注"
    },
    "createTime": {
      "bsonType": "timestamp",
      "title": "创建时间",
      "description": "创建时间"
    },
    "updateTime": {
      "bsonType": "timestamp",
      "title": "更新时间",
      "description": "更新时间"
    }
  }
}
