{
  "bsonType": "object",
  "required": ["organizationId", "userId", "joinTime"],
  "properties": {
    "_id": {
      "description": "成员记录ID"
    },
    "organizationId": {
      "bsonType": "string",
      "title": "组织ID",
      "description": "组织ID",
      "foreignKey": "alumni-organizations._id"
    },
    "userId": {
      "bsonType": "string",
      "title": "用户ID",
      "description": "用户ID",
      "foreignKey": "uni-id-users._id"
    },
    "role": {
      "bsonType": "string",
      "title": "角色",
      "description": "creator-创建者/admin-管理员/member-普通成员",
      "enum": ["creator", "admin", "member"],
      "default": "member"
    },
    "status": {
      "bsonType": "int",
      "title": "状态",
      "description": "0-待审核 1-已加入 -1-已退出",
      "enum": [-1, 0, 1],
      "default": 0
    },
    "joinTime": {
      "bsonType": "timestamp",
      "title": "加入时间",
      "description": "加入时间"
    },
    "leaveTime": {
      "bsonType": "timestamp",
      "title": "退出时间",
      "description": "退出时间"
    }
  }
}
